{
  "name": "cripex",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "db:migrate": "pnpm --filter @cripex/db migrate",
    "db:seed": "pnpm --filter @cripex/db seed",
    "contracts:test": "pnpm --filter @cripex/contracts test",
    "contracts:deploy:local": "pnpm --filter @cripex/contracts deploy:local"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "^5.7.2",
    "prettier": "^3.4.2"
  },
  "packageManager": "pnpm@9.14.4",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "engines": {
    "node": ">=20"
  }
}
